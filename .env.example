NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key (Supabase project settings > API) — only used by the
# /api/cron/process-automation route, never exposed to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret the cron scheduler must send as `Authorization: Bearer <value>`.
CRON_SECRET=

# Resend — https://resend.com
RESEND_API_KEY=
# Deprecated for tenant/lead email — each account configures From in Settings → Email.
# Optional: platform/system emails only (e.g. auth invites) if needed later.
RESEND_FROM_EMAIL=

# Inbound reply capture — configure inbound subdomain MX in Resend, then subscribe
# email.received webhooks to /api/webhooks/resend-inbound
RESEND_WEBHOOK_SECRET=
INBOUND_EMAIL_DOMAIN=
REPLY_TOKEN_TTL_DAYS=365

# HMAC secret for marketing unsubscribe links (sequences)
UNSUBSCRIBE_SECRET=

# Comma-separated emails allowed to access /platform/email (internal ops)
PLATFORM_ADMIN_EMAILS=

# Optional: POST JSON alerts when email webhooks fail processing
ALERT_WEBHOOK_URL=

# Public site URL for unsubscribe links (production)
NEXT_PUBLIC_SITE_URL=
